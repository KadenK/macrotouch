{
  "name": "macrotouch",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "nuxt dev",
    "dev:electron": "concurrently -k \"nuxt dev\" \"wait-on http://localhost:4321 && cross-env NODE_ENV=development electron .\"",
    "build": "nuxt build",
    "generate": "cross-env NUXT_HASH_ROUTER=true nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "electron:preview": "npm run build && cross-env NODE_ENV=production electron .",
    "dist": "npm run build && cross-env NODE_ENV=production electron-builder"
  },
  "dependencies": {
    "@iconify-json/ic": "^1.2.4",
    "@iconify/utils": "^3.1.0",
    "@nuxt/icon": "^2.2.1",
    "@pinia/nuxt": "^0.11.3",
    "node-notifier": "^10.0.1",
    "nuxt": "^4.3.1",
    "qrcode": "^1.5.4",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.1",
    "@types/node-notifier": "^8.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss-nested": "^7.0.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "asar": false,
    "appId": "com.macrotouch.app",
    "productName": "MacroTouch",
    "icon": "images/macrotouch-logo.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".output/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "author": {
    "name": "Kaden Keep",
    "email": "me@kadenkeep.com"
  }
}
